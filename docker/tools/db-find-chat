#!/bin/bash
# Find chat by name (fuzzy search)
# Usage: db-find-chat --name "<name>"

set -euo pipefail

DB_PATH="${AGENT_DB_PATH:-/data/agent.db}"
NAME=""

while [[ $# -gt 0 ]]; do
  case $1 in
    --name)
      NAME="$2"
      shift 2
      ;;
    *)
      shift
      ;;
  esac
done

if [ -z "$NAME" ]; then
  echo '{"error": "missing --name parameter"}' >&2
  exit 1
fi

# Escape single quotes in name for SQL
ESCAPED_NAME="${NAME//\'/\'\'}"

sqlite3 -json "$DB_PATH" \
  "SELECT * FROM chats WHERE name LIKE '%${ESCAPED_NAME}%' ORDER BY last_activity_at DESC LIMIT 10"
