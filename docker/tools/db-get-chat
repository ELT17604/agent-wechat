#!/bin/bash
# Get chat by ID
# Usage: db-get-chat --id <id>

set -euo pipefail

DB_PATH="${AGENT_DB_PATH:-/data/agent.db}"
ID=""

while [[ $# -gt 0 ]]; do
  case $1 in
    --id)
      ID="$2"
      shift 2
      ;;
    *)
      shift
      ;;
  esac
done

if [ -z "$ID" ]; then
  echo '{"error": "missing --id parameter"}' >&2
  exit 1
fi

# Use parameterized query to prevent SQL injection
sqlite3 -json "$DB_PATH" \
  "SELECT * FROM chats WHERE id = '$ID' LIMIT 1"
