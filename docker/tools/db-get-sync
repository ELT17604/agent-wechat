#!/bin/bash
# Get sync state value
# Usage: db-get-sync <key>

set -euo pipefail

DB_PATH="${AGENT_DB_PATH:-/data/agent.db}"

if [ -z "${1:-}" ]; then
  echo '{"error": "missing key parameter"}' >&2
  exit 1
fi

KEY="${1//\'/\'\'}"

sqlite3 "$DB_PATH" \
  "SELECT value FROM sync_state WHERE key = '$KEY'"
