#!/bin/bash
# List messages for a chat
# Usage: db-list-messages --chat-id <id> [--limit N] [--since <timestamp>]

set -euo pipefail

DB_PATH="${AGENT_DB_PATH:-/data/agent.db}"
CHAT_ID=""
LIMIT=50
SINCE=""

while [[ $# -gt 0 ]]; do
  case $1 in
    --chat-id)
      CHAT_ID="$2"
      shift 2
      ;;
    --limit)
      LIMIT="$2"
      shift 2
      ;;
    --since)
      SINCE="$2"
      shift 2
      ;;
    *)
      shift
      ;;
  esac
done

if [ -z "$CHAT_ID" ]; then
  echo '{"error": "missing --chat-id parameter"}' >&2
  exit 1
fi

# Escape single quotes
CHAT_ID_ESC="${CHAT_ID//\'/\'\'}"
SINCE_ESC="${SINCE//\'/\'\'}"

if [ -n "$SINCE" ]; then
  sqlite3 -json "$DB_PATH" \
    "SELECT * FROM messages WHERE chat_id = '$CHAT_ID_ESC' AND timestamp_parsed > '$SINCE_ESC' ORDER BY timestamp_parsed DESC LIMIT $LIMIT"
else
  sqlite3 -json "$DB_PATH" \
    "SELECT * FROM messages WHERE chat_id = '$CHAT_ID_ESC' ORDER BY timestamp_parsed DESC LIMIT $LIMIT"
fi
