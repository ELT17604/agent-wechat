#!/bin/bash
# Mark a chat as read (set unread_count to 0)
# Usage: db-mark-chat-read --chat-id <id>

set -euo pipefail

DB_PATH="${AGENT_DB_PATH:-/data/agent.db}"
CHAT_ID=""

while [[ $# -gt 0 ]]; do
  case $1 in
    --chat-id)
      CHAT_ID="$2"
      shift 2
      ;;
    *)
      shift
      ;;
  esac
done

if [ -z "$CHAT_ID" ]; then
  echo '{"error": "missing --chat-id parameter"}' >&2
  exit 1
fi

CHAT_ID_ESC="${CHAT_ID//\'/\'\'}"

sqlite3 "$DB_PATH" \
  "UPDATE chats SET unread_count = 0, updated_at = datetime('now') WHERE id = '$CHAT_ID_ESC'"

# Return the updated chat
db-get-chat --id "$CHAT_ID"
