#!/bin/bash
# Update specific fields of a chat
# Usage: db-update-chat --id <id> [--name "..."] [--unread N] [--preview "..."] [--sender "..."] [--search-terms '["term1","term2"]'] [--scroll-hint N]

set -euo pipefail

DB_PATH="${AGENT_DB_PATH:-/data/agent.db}"

ID=""
UPDATES=""

escape_sql() {
  echo "${1//\'/\'\'}"
}

while [[ $# -gt 0 ]]; do
  case $1 in
    --id)
      ID="$2"
      shift 2
      ;;
    --name)
      VAL=$(escape_sql "$2")
      UPDATES="${UPDATES}, name = '$VAL'"
      shift 2
      ;;
    --unread)
      UPDATES="${UPDATES}, unread_count = $2"
      shift 2
      ;;
    --preview)
      VAL=$(escape_sql "$2")
      UPDATES="${UPDATES}, last_message_preview = '$VAL'"
      shift 2
      ;;
    --sender)
      VAL=$(escape_sql "$2")
      UPDATES="${UPDATES}, last_message_sender = '$VAL'"
      shift 2
      ;;
    --activity-at)
      VAL=$(escape_sql "$2")
      UPDATES="${UPDATES}, last_activity_at = '$VAL'"
      shift 2
      ;;
    --search-terms)
      VAL=$(escape_sql "$2")
      UPDATES="${UPDATES}, search_terms = '$VAL'"
      shift 2
      ;;
    --scroll-hint)
      UPDATES="${UPDATES}, scroll_position_hint = $2"
      shift 2
      ;;
    *)
      shift
      ;;
  esac
done

if [ -z "$ID" ]; then
  echo '{"error": "missing --id parameter"}' >&2
  exit 1
fi

if [ -z "$UPDATES" ]; then
  echo '{"error": "no fields to update"}' >&2
  exit 1
fi

# Remove leading comma
UPDATES="${UPDATES:2}"
ID_ESC=$(escape_sql "$ID")

sqlite3 "$DB_PATH" \
  "UPDATE chats SET $UPDATES, updated_at = datetime('now') WHERE id = '$ID_ESC'"

# Return the updated chat
db-get-chat --id "$ID"
