#!/bin/bash
# Upsert chat (insert or update)
# Usage: db-upsert-chat --id <id> --name <name> [--unread N] [--preview "..."] [--sender "..."] [--activity-at "..."] [--is-group] [--is-pinned] [--avatar-desc "..."]

set -euo pipefail

DB_PATH="${AGENT_DB_PATH:-/data/agent.db}"

ID=""
NAME=""
UNREAD="0"
PREVIEW=""
SENDER=""
ACTIVITY_AT=""
IS_GROUP="0"
IS_PINNED="0"
AVATAR_DESC=""

while [[ $# -gt 0 ]]; do
  case $1 in
    --id)
      ID="$2"
      shift 2
      ;;
    --name)
      NAME="$2"
      shift 2
      ;;
    --unread)
      UNREAD="$2"
      shift 2
      ;;
    --preview)
      PREVIEW="$2"
      shift 2
      ;;
    --sender)
      SENDER="$2"
      shift 2
      ;;
    --activity-at)
      ACTIVITY_AT="$2"
      shift 2
      ;;
    --is-group)
      IS_GROUP="1"
      shift
      ;;
    --is-pinned)
      IS_PINNED="1"
      shift
      ;;
    --avatar-desc)
      AVATAR_DESC="$2"
      shift 2
      ;;
    *)
      shift
      ;;
  esac
done

if [ -z "$ID" ] || [ -z "$NAME" ]; then
  echo '{"error": "missing required --id and --name parameters"}' >&2
  exit 1
fi

# Escape single quotes for SQL
escape_sql() {
  echo "${1//\'/\'\'}"
}

ID_ESC=$(escape_sql "$ID")
NAME_ESC=$(escape_sql "$NAME")
PREVIEW_ESC=$(escape_sql "$PREVIEW")
SENDER_ESC=$(escape_sql "$SENDER")
ACTIVITY_ESC=$(escape_sql "$ACTIVITY_AT")
AVATAR_ESC=$(escape_sql "$AVATAR_DESC")

sqlite3 "$DB_PATH" <<EOF
INSERT INTO chats (id, name, unread_count, last_message_preview, last_message_sender, last_activity_at, is_group, is_pinned, avatar_description, updated_at)
VALUES ('$ID_ESC', '$NAME_ESC', $UNREAD, NULLIF('$PREVIEW_ESC', ''), NULLIF('$SENDER_ESC', ''), NULLIF('$ACTIVITY_ESC', ''), $IS_GROUP, $IS_PINNED, NULLIF('$AVATAR_ESC', ''), datetime('now'))
ON CONFLICT(id) DO UPDATE SET
  name = excluded.name,
  unread_count = excluded.unread_count,
  last_message_preview = COALESCE(excluded.last_message_preview, chats.last_message_preview),
  last_message_sender = COALESCE(excluded.last_message_sender, chats.last_message_sender),
  last_activity_at = COALESCE(excluded.last_activity_at, chats.last_activity_at),
  is_group = excluded.is_group,
  is_pinned = excluded.is_pinned,
  avatar_description = COALESCE(excluded.avatar_description, chats.avatar_description),
  updated_at = datetime('now');
EOF

# Return the updated chat
db-get-chat --id "$ID"
