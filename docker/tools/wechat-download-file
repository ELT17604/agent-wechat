#!/bin/bash
# Download attachment for a message
# Usage: wechat-download-file --message-id <id>
# Returns: JSON with base64 content and mime type

set -euo pipefail

DB_PATH="${AGENT_DB_PATH:-/data/agent.db}"
MESSAGE_ID=""

while [[ $# -gt 0 ]]; do
  case $1 in
    --message-id)
      MESSAGE_ID="$2"
      shift 2
      ;;
    *)
      shift
      ;;
  esac
done

if [ -z "$MESSAGE_ID" ]; then
  echo '{"error": "missing --message-id parameter"}' >&2
  exit 1
fi

MESSAGE_ID_ESC="${MESSAGE_ID//\'/\'\'}"

# Get the download path from the database
DOWNLOAD_PATH=$(sqlite3 "$DB_PATH" \
  "SELECT download_path FROM messages WHERE id = '$MESSAGE_ID_ESC' AND is_downloaded = 1 LIMIT 1")

if [ -z "$DOWNLOAD_PATH" ]; then
  echo '{"error": "message not found or not downloaded"}' >&2
  exit 1
fi

if [ ! -f "$DOWNLOAD_PATH" ]; then
  echo '{"error": "file not found at download path"}' >&2
  exit 1
fi

# Detect mime type
MIME_TYPE=$(file -b --mime-type "$DOWNLOAD_PATH")

# Get filename
FILENAME=$(basename "$DOWNLOAD_PATH")

# Encode to base64
BASE64_CONTENT=$(base64 -w 0 "$DOWNLOAD_PATH")

# Output as JSON
cat <<EOF
{"base64": "$BASE64_CONTENT", "mimeType": "$MIME_TYPE", "filename": "$FILENAME"}
EOF
