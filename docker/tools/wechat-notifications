#!/bin/bash
# Read pending desktop notifications
# Usage: wechat-notifications
# Returns JSON array of recent notifications

set -euo pipefail

NOTIFICATION_LOG="${NOTIFICATION_LOG:-/tmp/notification_log.json}"

# If notification log exists, output it
if [ -f "$NOTIFICATION_LOG" ]; then
  cat "$NOTIFICATION_LOG"
else
  # No notifications logged yet
  echo "[]"
fi

