    "drizzle-orm": "^0.45.1",
    "jsqr": "^1.4.0",
    "pngjs": "^7.0.0",
    "qrcode": "^1.5.4",
    "superjson": "^2.2.6",
    "ws": "^8.18.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^20.11.19",
    "@types/pngjs": "^6.0.5",
    "@types/qrcode": "^1.5.6",
    "@types/ws": "^8.5.14",
    "drizzle-kit": "^0.31.8",
    "typescript": "^5.4.5"
