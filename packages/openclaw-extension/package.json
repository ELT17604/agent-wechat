{
  "name": "@agent-wechat/wechat",
  "version": "0.3.1",
  "type": "module",
  "files": [
    "dist",
    "openclaw.plugin.json"
  ],
  "scripts": {
    "build": "esbuild index.ts --bundle --format=esm --platform=node --outfile=dist/index.js --external:openclaw"
  },
  "devDependencies": {
    "@agent-wechat/shared": "workspace:*",
    "esbuild": "^0.25.0"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "channel": {
      "id": "wechat",
      "label": "WeChat",
      "selectionLabel": "WeChat (微信)",
      "aliases": [
        "weixin"
      ],
      "order": 80
    },
    "install": {
      "npmSpec": "@agent-wechat/wechat"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thisnick/agent-wechat.git",
    "directory": "packages/openclaw-extension"
  }
}
